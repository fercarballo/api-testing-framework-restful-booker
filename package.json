{
  "name": "api-testing-framework-restful-booker",
  "version": "1.0.0",
  "description": "Framework de testing de API con Playwright + TypeScript + Zod sobre Restful-Booker. Proyecto de portfolio para QA Automation Sr.",
  "author": "Fernando Carballo",
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:debug": "playwright test --debug",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "api-testing",
    "qa-automation",
    "contract-testing",
    "zod"
  ],
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "zod": "^3.24.0"
  }
}
