# ─────────────────────────────────────────────────────────────
# Variables de entorno de ejemplo.
# Copiá este archivo a ".env" y ajustá los valores si lo necesitás:
#     cp .env.example .env
#
# El archivo ".env" está en .gitignore: NUNCA se sube al repo.
# ─────────────────────────────────────────────────────────────

# URL base de la API bajo prueba.
API_BASE_URL=https://restful-booker.herokuapp.com

# Credenciales para obtener el token de autenticación.
# NOTA: en Restful-Booker estas credenciales son PÚBLICAS y de demo.
# En un proyecto real, estas variables vivirían en el gestor de secretos
# del CI (GitHub Secrets, etc.), nunca en el código ni en el repo.
API_USERNAME=admin
API_PASSWORD=password123
